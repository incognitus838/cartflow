# PostgreSQL — CartFlow uses the "cartflow" schema (safe alongside bank-app on same Neon DB)
# Local: direct Neon host. Vercel: use -pooler host (sync-vercel-env.mjs does this automatically).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Session / auth secret (32+ random characters — never commit real values)
AUTH_SECRET="replace-with-a-long-random-secret"

# App URL (production Vercel URL or http://localhost:3001 for dev)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Cache bust after reseed/scripts (any random string)
REVALIDATE_SECRET="replace-with-a-random-secret"

# Vercel CLI token for npm run vercel:sync-env (https://vercel.com/account/tokens)
# VERCEL_TOKEN=""

# Paystack (https://paystack.com)
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# Flutterwave (https://flutterwave.com)
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# 1. Create account: https://resend.com
# 2. API Keys → Create API Key → copy re_...
# 3. Domains → Add cartflow.com.ng → add SPF/DKIM/DMARC DNS records Resend shows
# 4. After domain is Verified, use hello@ / orders@ below
#
# Until the domain is verified, test with Resend's sandbox from:
#   TRANSACTIONAL_FROM_EMAIL="CartFlow <onboarding@resend.dev>"
# and send only to the email on your Resend account.
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
TRANSACTIONAL_FROM_EMAIL="CartFlow <hello@cartflow.com.ng>"
NOTIFICATION_FROM_EMAIL="CartFlow Orders <orders@cartflow.com.ng>"
# Optional: npm run test:email -- you@example.com
# EMAIL_TEST_TO="you@example.com"

# ZeptoMail (optional alternative — only if not using Resend)
# ZEPTOMAIL_SEND_TOKEN=""
# EMAIL_PROVIDER="zeptomail"

# SMS notifications (https://twilio.com) — optional
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
