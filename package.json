{
  "name": "cartflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx prisma generate && npx next dev --webpack -p 3001",
    "build": "npx next build",
    "vercel-build": "prisma generate && node scripts/apply-approval-schema.mjs && node scripts/apply-product-sort-schema.mjs && node scripts/apply-product-media-schema.mjs && node scripts/apply-delivery-zones-schema.mjs && next build",
    "start": "npx next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "npx dotenv-cli -e .env.local -- prisma db push",
    "db:team": "npx dotenv-cli -e .env.local -- node scripts/apply-team-schema.mjs",
    "db:approval": "npx dotenv-cli -e .env.local -- node scripts/apply-approval-schema.mjs",
    "db:product-media": "npx dotenv-cli -e .env.local -- node scripts/apply-product-media-schema.mjs",
    "db:delivery-zones": "npx dotenv-cli -e .env.local -- node scripts/apply-delivery-zones-schema.mjs",
    "db:sync-stock": "npx dotenv-cli -e .env.local -- node scripts/sync-product-stock-from-variants.mjs",
    "db:backfill-media": "npx dotenv-cli -e .env.local -- node scripts/backfill-product-media-blob.mjs",
    "run:all": "npx dotenv-cli -e .env.local -- node scripts/run-all.mjs",
    "db:migrate": "npx dotenv-cli -e .env.local -- prisma migrate dev",
    "db:studio": "npx dotenv-cli -e .env.local -- prisma studio",
    "db:seed": "npx dotenv-cli -e .env.local -- node prisma/seed.mjs",
    "db:ensure-users": "npx dotenv-cli -e .env.local -- node scripts/ensure-demo-users.mjs",
    "db:ensure-bank": "npx dotenv-cli -e .env.local -- node scripts/ensure-demo-bank.mjs",
    "db:reseed-skincare": "npx dotenv-cli -e .env.local -- node scripts/reseed-ada-skincare.mjs",
    "db:seed-beauty": "npx dotenv-cli -e .env.local -- node scripts/seed-glow-beauty.mjs",
    "db:seed-demo-order": "npx dotenv-cli -e .env.local -- node scripts/seed-glow-beauty-demo-order.mjs",
    "db:usage": "npx dotenv-cli -e .env.local -- node scripts/db-usage.mjs",
    "db:enrich-gallery": "npx dotenv-cli -e .env.local -- node scripts/enrich-product-gallery.mjs",
    "db:reset": "npx dotenv-cli -e .env.local -- prisma db push --force-reset && npm run db:seed",
    "db:reset-glow-beauty": "npx dotenv-cli -e .env.local -- node scripts/reset-glow-beauty-only.mjs",
    "test:api": "npx dotenv-cli -e .env.local -- node scripts/audit-api-smoke.mjs",
    "test:e2e": "playwright test",
    "test": "npm run test:api",
    "vercel:sync-env": "node scripts/sync-vercel-env.mjs",
    "docs:white-paper-pdf": "node scripts/generate-white-paper-pdf.mjs",
    "docs:vendor-pitch-pdf": "node scripts/generate-vendor-pitch-pdf.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "@vercel/blob": "^0.27.3",
    "bcryptjs": "^3.0.2",
    "jose": "^6.1.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "prisma": "^6.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "docx": "^9.7.1",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
